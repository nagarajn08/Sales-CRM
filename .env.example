# ─────────────────────────────────────────────────────────────────────────────
# TrackmyLead — Production Environment Variables
# Copy this file to .env and fill in every value before deploying.
#
#   cp .env.example .env && nano .env
#
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_USER=salescrm
DB_PASSWORD=           # generate: openssl rand -hex 16
DB_NAME=salescrm

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=            # generate: openssl rand -hex 32  ← REQUIRED, keeps sessions secure
FRONTEND_URL=https://trackmylead.in
BACKEND_URL=https://trackmylead.in

# ── First Admin Account (created automatically on first boot) ─────────────────
ADMIN_EMAIL=admin@trackmylead.in
ADMIN_PASSWORD=        # set a strong password
ADMIN_NAME=Administrator

# ── SMTP — outgoing email for OTPs, password resets, notifications ────────────
# Gmail example: use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=             # App Password (not your Gmail password)
SMTP_FROM=TrackmyLead <noreply@trackmylead.in>

# ── Razorpay — leave empty to run in demo/mock mode ──────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Twilio — WhatsApp/SMS follow-up reminders (leave empty to disable) ────────
# WhatsApp: TWILIO_FROM_NUMBER=whatsapp:+14155238886
# SMS:      TWILIO_FROM_NUMBER=+91XXXXXXXXXX
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Sentry — error tracking (leave empty to disable) ─────────────────────────
SENTRY_DSN=
