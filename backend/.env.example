# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://salescrm:salescrm123@localhost:5432/salescrm

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-64-char-secret-key-here-change-this
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App URLs ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ── Superadmin seed account ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Administrator

# ── Razorpay (leave empty for demo/mock mode) ─────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Twilio — WhatsApp OTP (signup verification) + follow-up reminders ─────────
# Mobile OTP is sent via WhatsApp. Use sandbox number during testing:
#   TWILIO_FROM_NUMBER=whatsapp:+14155238886
# In production set your verified WhatsApp Business number:
#   TWILIO_FROM_NUMBER=whatsapp:+91XXXXXXXXXX
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=whatsapp:+14155238886

# ── Sentry error tracking (leave empty to disable) ────────────────────────────
SENTRY_DSN=
