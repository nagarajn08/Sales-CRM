# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://salescrm:salescrm123@localhost:5432/salescrm

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-64-char-secret-key-here-change-this
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App URLs ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ── Superadmin seed account ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Administrator

# ── Razorpay (leave empty for demo/mock mode) ─────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Fast2SMS — WhatsApp OTP for signup verification (leave empty to disable) ───
FAST2SMS_API_KEY=

# ── Twilio — WhatsApp/SMS follow-up reminders (leave empty to disable) ─────────
# For WhatsApp: TWILIO_FROM_NUMBER=whatsapp:+14155238886
# For SMS:      TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Sentry error tracking (leave empty to disable) ────────────────────────────
SENTRY_DSN=
